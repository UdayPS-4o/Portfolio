# API configuration (copy to .env for local dev)
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# SQLite location (in Docker this is a mounted volume: /app/data/portfolio.db)
DB_PATH=./data/portfolio.db

# CORS origin for the REST API (use your domain in prod, e.g. https://udayps.com)
CORS_ORIGIN=*

# Protect /api/stats with a bearer token (leave empty to allow open access in dev)
ADMIN_TOKEN=

# IP geolocation via ip-api.com (set to false to disable outbound lookups)
GEO_ENABLED=true
